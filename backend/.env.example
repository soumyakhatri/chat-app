PORT=3001
SERVER_ID=server-1
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/chat-app
REDIS_URL=redis://127.0.0.1:6379

# Auth (Step 1) — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Redis: npm run redis:up (from backend/) — requires Docker
# Multi-instance: use npm run dev:server1 / dev:server2 (or dev:both)
# Or: $env:PORT=3002; $env:SERVER_ID="server-2"; npm run dev
